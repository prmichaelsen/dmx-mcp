{
  "name": "dmx-mcp",
  "version": "0.7.0",
  "type": "module",
  "description": "MCP server for DMX lighting control via OLA",
  "main": "dist/index.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "emulator": "tsx src/emulator/main.ts",
    "dev:emulator": "tsx watch src/emulator/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
